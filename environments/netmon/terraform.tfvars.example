# Copy this file to terraform.tfvars and fill in your values.
# DO NOT commit terraform.tfvars — it may contain sensitive IPs or IDs.

aws_region  = "eu-west-1"
environment = "production"

# REGIONAL for ALB/API Gateway; CLOUDFRONT requires region = us-east-1
waf_scope = "REGIONAL"

# ── Network ───────────────────────────────────────────────────────────────────
vpc_id     = "vpc-xxxxxxxxxxxxxxxxx"
subnet_ids = [
  "subnet-xxxxxxxxxxxxxxxxx",   # eu-west-1a
  "subnet-yyyyyyyyyyyyyyyyy",   # eu-west-1b
]

alb_internal               = false
enable_deletion_protection = false

# ── Origin IP (backend server) ────────────────────────────────────────────────
origin_ip                = "10.0.1.50"   # ← set your backend server IP
origin_port              = 80            # ← set your backend server port
origin_availability_zone = "all"         # "all" for external/on-prem IPs
health_check_path        = "/"

# ── TLS Certificate ───────────────────────────────────────────────────────────
# Option A — let Terraform request and manage the ACM certificate:
#   Set certificate_domain to your domain (or wildcard).
#   If your DNS is on Route53, also set route53_zone_id for fully automatic validation.
#   If DNS is elsewhere, leave route53_zone_id empty: after the first terraform apply,
#   read the "certificate_validation_records" output and add the CNAMEs to your DNS,
#   then run terraform apply again.
certificate_domain = "netmon2.technacy.it"

# Optional: add a wildcard SAN so the cert also covers *.technacy.it
# certificate_san = ["*.technacy.it"]
certificate_san = []

# Route53 hosted zone ID — enables fully automatic DNS validation.
# Find it at: AWS Console → Route53 → Hosted zones → technacy.it
# route53_zone_id = "Z0123456789ABCDEFGHIJ"
route53_zone_id = ""

# Option B — paste an existing ACM certificate ARN (overrides certificate_domain):
# certificate_arn = "arn:aws:acm:eu-west-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
certificate_arn = ""

# ── IP Allowlist ──────────────────────────────────────────────────────────────
ip_allowlist_ipv4 = [
  # "203.0.113.10/32",   # Office public IP
  # "198.51.100.0/24",   # VPN range
]
ip_allowlist_ipv6 = []

# ── IP Blocklist ──────────────────────────────────────────────────────────────
ip_blocklist_ipv4 = []
ip_blocklist_ipv6 = []

# ── Rate Limiting ─────────────────────────────────────────────────────────────
rate_limit_enabled   = true
rate_limit_threshold = 2000

# ── Geo Blocking ─────────────────────────────────────────────────────────────
geo_block_enabled       = false
geo_block_country_codes = []

# ── Rule Exceptions ───────────────────────────────────────────────────────────
exclude_size_restriction_body = false
exclude_hosting_provider_ips  = false

# ── Bot Control ───────────────────────────────────────────────────────────────
bot_control_enabled = false

# ── Logging ───────────────────────────────────────────────────────────────────
log_retention_days = 90
