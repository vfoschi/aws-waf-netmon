# Copy this file to terraform.tfvars and fill in your values.
# DO NOT commit terraform.tfvars — it may contain sensitive IPs or IDs.

aws_region  = "eu-west-1"
environment = "production"

# ── Origin IP ─────────────────────────────────────────────────────────────────
# Public IP of your backend server (any public IP is supported via CloudFront).
origin_ip   = "2.40.172.107"   # ← your backend server public IP
origin_port = 80               # ← backend HTTP port

# ── CloudFront ────────────────────────────────────────────────────────────────
# Domains served via CloudFront. These must match the certificate.
cloudfront_aliases = ["netmon2.technacy.it"]

# PriceClass_100 = US/Europe/Israel edge locations (cheapest, usually enough)
# PriceClass_All = all edge locations worldwide
cloudfront_price_class = "PriceClass_100"

# ── TLS Certificate (us-east-1, required by CloudFront) ──────────────────────
certificate_domain = "*.technacy.it"
certificate_san    = ["technacy.it"]

# Route53 hosted zone ID for automatic DNS validation
# AWS Console → Route53 → Hosted zones → technacy.it → Hosted zone ID
route53_zone_id = "ZXXXXXXXXXXXXXXXXXXXX"   # ← replace with your actual zone ID

certificate_arn = ""   # leave empty when using certificate_domain

# ── IP Allowlist ──────────────────────────────────────────────────────────────
# Use /32 for single IPs. For subnets use network address (e.g. 93.39.208.56/29).
ip_allowlist_ipv4 = [
  # "93.39.208.62/32",   # office IP
]
ip_allowlist_ipv6 = []

# ── IP Blocklist ──────────────────────────────────────────────────────────────
ip_blocklist_ipv4 = []
ip_blocklist_ipv6 = []

# ── Rate Limiting ─────────────────────────────────────────────────────────────
rate_limit_enabled   = true
rate_limit_threshold = 2000

# ── Geo Blocking ─────────────────────────────────────────────────────────────
geo_block_enabled       = false
geo_block_country_codes = []

# ── Rule Exceptions ───────────────────────────────────────────────────────────
exclude_size_restriction_body = false
exclude_hosting_provider_ips  = false

# ── Bot Control ───────────────────────────────────────────────────────────────
bot_control_enabled = false

# ── Logging ───────────────────────────────────────────────────────────────────
log_retention_days = 90
