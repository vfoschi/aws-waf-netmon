# Copy this file to terraform.tfvars and fill in your values.
# DO NOT commit terraform.tfvars — it may contain sensitive IPs or IDs.

aws_region  = "eu-west-1"
environment = "production"
waf_scope   = "REGIONAL"

# ── Network ───────────────────────────────────────────────────────────────────
vpc_id     = "vpc-xxxxxxxxxxxxxxxxx"
subnet_ids = [
  "subnet-xxxxxxxxxxxxxxxxx",   # eu-west-1a
  "subnet-yyyyyyyyyyyyyyyyy",   # eu-west-1b
]

alb_internal               = false
enable_deletion_protection = false

# ── Origin IP (backend server) ────────────────────────────────────────────────
# All traffic that passes WAF inspection is forwarded to this IP.
origin_ip                = "10.0.1.50"   # ← set your backend server IP
origin_port              = 80            # ← set your backend server port
origin_availability_zone = "all"         # "all" for external/on-prem IPs
health_check_path        = "/"

# ── TLS Certificate ───────────────────────────────────────────────────────────
# Wildcard certificate *.technacy.it with automatic Route53 DNS validation.
# The SAN "technacy.it" covers also the apex domain.
certificate_domain = "*.technacy.it"
certificate_san    = ["technacy.it"]

# Route53 hosted zone ID for technacy.it — find it at:
# AWS Console → Route53 → Hosted zones → technacy.it → Hosted zone ID
route53_zone_id = "ZXXXXXXXXXXXXXXXXXXXX"   # ← replace with your actual zone ID

# Leave empty — certificate is managed above via certificate_domain
certificate_arn = ""

# ── IP Allowlist ──────────────────────────────────────────────────────────────
# IPs that bypass ALL WAF rules and are always allowed.
ip_allowlist_ipv4 = [
  # "203.0.113.10/32",   # Office public IP
  # "198.51.100.0/24",   # VPN range
]
ip_allowlist_ipv6 = []

# ── IP Blocklist ──────────────────────────────────────────────────────────────
ip_blocklist_ipv4 = []
ip_blocklist_ipv6 = []

# ── Rate Limiting ─────────────────────────────────────────────────────────────
rate_limit_enabled   = true
rate_limit_threshold = 2000   # requests per 5 minutes per source IP

# ── Geo Blocking ─────────────────────────────────────────────────────────────
geo_block_enabled       = false
geo_block_country_codes = []
# Example — block specific countries:
# geo_block_enabled       = true
# geo_block_country_codes = ["CN", "RU", "KP", "IR"]

# ── Rule Exceptions ───────────────────────────────────────────────────────────
exclude_size_restriction_body = false
exclude_hosting_provider_ips  = false

# ── Bot Control ───────────────────────────────────────────────────────────────
bot_control_enabled = false

# ── Logging ───────────────────────────────────────────────────────────────────
log_retention_days = 90
