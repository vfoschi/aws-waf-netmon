# Copy this file to terraform.tfvars and fill in your values.
# DO NOT commit terraform.tfvars — it may contain sensitive IPs or IDs.

aws_region  = "eu-west-1"
environment = "production"
waf_scope   = "REGIONAL"

# ── Network (OPTIONAL) ────────────────────────────────────────────────────────
# Leave commented out to use the account's default VPC and its public subnets
# automatically. This is the recommended setup when origin_ip is a public IP
# outside AWS.
#
# vpc_id     = "vpc-0abc1234def567890"
# subnet_ids = ["subnet-0abc1234def567890", "subnet-0xyz9876abc543210"]

alb_internal               = false
enable_deletion_protection = false

# ── Origin IP (backend server — can be a public IP outside AWS) ───────────────
origin_ip                = "1.2.3.4"     # ← set your backend server public IP
origin_port              = 80            # ← set your backend server port
origin_availability_zone = "all"         # "all" is required for IPs outside the VPC
health_check_path        = "/"

# ── TLS Certificate ───────────────────────────────────────────────────────────
certificate_domain = "*.technacy.it"
certificate_san    = ["technacy.it"]

# Route53 hosted zone ID for technacy.it
# AWS Console → Route53 → Hosted zones → technacy.it → Hosted zone ID
route53_zone_id = "ZXXXXXXXXXXXXXXXXXXXX"   # ← replace with your actual zone ID

certificate_arn = ""

# ── IP Allowlist ──────────────────────────────────────────────────────────────
# IMPORTANT: CIDRs must use network address notation (host bits = 0).
# Examples:
#   "93.39.208.62/32"  → single host (use /32 if unsure)
#   "93.39.208.56/29"  → subnet (network address, not a host address)
#   "10.0.0.0/24"      → entire /24 block
ip_allowlist_ipv4 = [
  # "203.0.113.10/32",
]
ip_allowlist_ipv6 = []

# ── IP Blocklist ──────────────────────────────────────────────────────────────
ip_blocklist_ipv4 = []
ip_blocklist_ipv6 = []

# ── Rate Limiting ─────────────────────────────────────────────────────────────
rate_limit_enabled   = true
rate_limit_threshold = 2000

# ── Geo Blocking ─────────────────────────────────────────────────────────────
geo_block_enabled       = false
geo_block_country_codes = []

# ── Rule Exceptions ───────────────────────────────────────────────────────────
exclude_size_restriction_body = false
exclude_hosting_provider_ips  = false

# ── Bot Control ───────────────────────────────────────────────────────────────
bot_control_enabled = false

# ── Logging ───────────────────────────────────────────────────────────────────
log_retention_days = 90
